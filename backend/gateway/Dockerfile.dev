FROM rust:1.82-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config \
    libssl-dev \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY Cargo.toml Cargo.lock ./
COPY gateway-app/Cargo.toml ./gateway-app/

RUN mkdir -p gateway-app/src && echo "fn main() {}" > gateway-app/src/main.rs
RUN cargo build --bin gateway 2>/dev/null || true

COPY . .

EXPOSE 8080

CMD ["cargo", "run", "--bin", "gateway"]
