# ==============================================================================
# FRONTEND & NODE (Next.js / UI)
# ==============================================================================
**/node_modules/
**/.next/
**/out/
**/next-env.d.ts
**/*.tsbuildinfo
**/*.bak
**/*.tmp
**/.env*.local
**/.env

# ==============================================================================
# BACKEND (Python / FastAPI / ML)
# ==============================================================================
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/ENV/
**/.pytest_cache/
**/backend/ml-service/app/models/*.pkl
**/backend/ml-service/app/models/*.h5
**/backend/ml-service/app/models/*.onnx

# ==============================================================================
# BACKEND (Rust / Axum Gateway)
# ==============================================================================
**/target/
**/*.rs.bk

# ==============================================================================
# INFRASTRUCTURE & PROBE
# ==============================================================================
**/infra/probe/reports/*
!**/infra/probe/reports/.gitkeep
**/infra/postgres/data/
**/infra/mongo/data/

# ==============================================================================
# SYSTEM & IDE
# ==============================================================================
**/.DS_Store
**/.idea/
**/.vscode/
